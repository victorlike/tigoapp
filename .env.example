# Copy this file to .env and fill in your values
# Supabase connection string (from Supabase > Settings > Database > Connection string)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# Secret key for JWT tokens (generate a random string)
SECRET_KEY=your-secret-key-here

# API key for Apps Script to authenticate when sending leads
APPS_SCRIPT_KEY=your-apps-script-api-key

# App settings
APP_ENV=production
